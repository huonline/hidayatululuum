<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Undangan Pernikahan</title>

<link href="https://fonts.googleapis.com/css2?family=Amiri&family=Poppins:wght@300&display=swap" rel="stylesheet">

<style>
body {
  margin:0;
  font-family:'Poppins', sans-serif;
  background: linear-gradient(to bottom, #87CEEB, #ffffff);
  color:#333;
  text-align:center;
}

/* COVER */
#cover {
  position:fixed;
  width:100%;
  height:100%;
  background: linear-gradient(rgba(135,206,235,0.7), rgba(255,255,255,0.9)),
              url('https://i.ibb.co/6J7k5ZP/islami-pattern.png');
  display:flex;
  justify-content:center;
  align-items:center;
  z-index:999;
}

.box {
  background:white;
  padding:25px;
  border-radius:15px;
  width:85%;
  max-width:400px;
}

h1 {
  font-family:'Amiri', serif;
  font-size:26px;
}

button {
  padding:10px 20px;
  background:#4da6ff;
  border:none;
  border-radius:20px;
  color:white;
  margin-top:15px;
}

/* SECTION */
.section {
  padding:40px 20px;
}

/* CARD */
.card {
  background:white;
  margin:20px;
  padding:20px;
  border-radius:15px;
}

/* MAP */
iframe {
  border-radius:10px;
}

/* ANIMASI */
.fade {
  opacity:0;
  transform:translateY(20px);
  transition:1s;
}
.show {
  opacity:1;
  transform:translateY(0);
}
</style>
</head>

<body>

<!-- COVER -->
<div id="cover">
  <div class="box">
    <h2>Undangan Pernikahan</h2>
    <h1>ASEP ILYAS &<br>AI SITI RAHMAWATI</h1>
    <p id="namaTamu"></p>
    <button onclick="buka()">Buka Undangan</button>
  </div>
</div>

<!-- MUSIK -->
<audio id="music" loop>
  <source src="">
</audio>

<!-- ISI -->
<div id="content" style="display:none;">

<!-- DOA -->
<div class="section fade">
  <h2>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيم</h2>
  <p>
  "Dan di antara tanda-tanda kekuasaan-Nya ialah Dia menciptakan pasangan-pasangan untukmu dari jenismu sendiri, 
  agar kamu cenderung dan merasa tenteram kepadanya, dan dijadikan-Nya di antaramu rasa kasih dan sayang."
  <br>(QS. Ar-Rum: 21)
  </p>
</div>

<!-- NAMA -->
<div class="card fade">
  <h2>ASEP ILYAS</h2>
  <p>&</p>
  <h2>AI SITI RAHMAWATI</h2>
</div>

<!-- TANGGAL -->
<div class="card fade">
  <h3>📅 Tanggal</h3>
  <p>07 Juni 2026</p>
</div>

<!-- MAP -->
<div class="card fade">
  <h3>📍 Lokasi</h3>
  <iframe src="https://https://maps.app.goo.gl/SD2KLbmzPeUiAhzp9"
    width="100%" height="200"></iframe>
</div>

</div>

<script>
// buka undangan + musik
function buka(){
  document.getElementById("cover").style.display="none";
  document.getElementById("content").style.display="block";
  let m = document.getElementById("music");
  m.volume = 0.3;
  m.play();
}

// nama tamu
const url = new URLSearchParams(window.location.search);
const nama = url.get('to');
document.getElementById("namaTamu").innerText =
  nama ? "Kepada Yth: " + nama : "Kepada Bapak/Ibu/Saudara/i";

// animasi
const faders = document.querySelectorAll(".fade");
window.addEventListener("scroll", () => {
  faders.forEach(el => {
    if(el.getBoundingClientRect().top < window.innerHeight - 50){
      el.classList.add("show");
    }
  });
});
</script>

</body>
</html>
